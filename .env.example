# Telegram bot token from @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Your personal numeric Telegram ID. Only this account can open the admin panel.
ADMIN_ID=YOUR_TELEGRAM_USER_ID

# Defaults for AI settings. The admin panel can override provider, models, and keys at runtime.
# AI provider: openai, anthropic, or google
AI_PROVIDER=google

# OpenAI settings
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1-mini

# Anthropic settings
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini settings
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# Telegram API credentials for the connected account client.
# Create an app at https://my.telegram.org/apps and copy api_id/api_hash.
TELEGRAM_API_ID=YOUR_TELEGRAM_API_ID
TELEGRAM_API_HASH=YOUR_TELEGRAM_API_HASH

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# SQLite database path
DB_PATH=data.db
